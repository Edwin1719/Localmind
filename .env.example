# Wigolo config
# El LLM provider que wigolo usa internamente para research/agent.
# Con 'ollama' usas tu modelo local — cero APIs externas.
WIGOLO_LLM_PROVIDER=ollama

# Modelo de Ollama que usa el agente (ChatOllama)
# Cambialo por cualquier modelo que tengas en 'ollama list'
OLLAMA_MODEL=gpt-oss:20b-cloud

# Solo necesario si cambias WIGOLO_LLM_PROVIDER a un proveedor cloud:
# GEMINI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
